POSTGRES_JDBC_URL=jdbc:postgresql://127.0.0.1:5432/postgres.public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_JDBC_URL=jdbc:redis://127.0.0.1:6379/0
JWT_SECRET_KEY=change-this-secret-key-to-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
DB_AUTO_CREATE_TABLES=true
DB_AUTO_CREATE_DATABASE=true
POSTGRES_MAINTENANCE_DB=postgres
LOGIN_CAPTCHA_THRESHOLD=2
LOGIN_FAIL_WINDOW_SECONDS=900
CAPTCHA_TTL_SECONDS=300
CAPTCHA_LENGTH=4
