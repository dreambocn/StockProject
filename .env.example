# =========================
# 运行环境与迁移模式
# =========================
APP_ENV=development
DB_SCHEMA_BOOTSTRAP_MODE=auto_apply
INIT_ADMIN_ENABLED=false
JOB_HEARTBEAT_STALE_SECONDS=120
JOB_RETENTION_DAYS=30
DB_POOL_SIZE=1
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT_SECONDS=15

# =========================
# PostgreSQL / Redis
# =========================
POSTGRES_JDBC_URL=jdbc:postgresql://127.0.0.1:5432/stockproject
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_MAINTENANCE_DB=postgres
DB_AUTO_CREATE_DATABASE=true
DB_AUTO_CREATE_TABLES=true

REDIS_JDBC_URL=jdbc:redis://127.0.0.1:6379/0
REDIS_USERNAME=
REDIS_PASSWORD=

# =========================
# Auth / 安全
# =========================
JWT_SECRET_KEY=change-this-secret-key-to-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=

# =========================
# 首个管理员（仅本地显式开启）
# =========================
INIT_ADMIN_USERNAME=
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=

# =========================
# 邮件与验证码
# =========================
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_PORT=465
SMTP_USE_SSL=true

# =========================
# 股票 / 新闻 / 任务
# =========================
TUSHARE_TOKEN=
STOCK_SYNC_TRADE_DAYS=120
STOCK_DAILY_CACHE_TTL_SECONDS=600
HOT_NEWS_CACHE_TTL_SECONDS=3600
POLICY_NEWS_CACHE_TTL_SECONDS=1800
POLICY_SYNC_ENABLED=true
POLICY_SYNC_LOOKBACK_DAYS=7
POLICY_SOURCE_TIMEOUT_SECONDS=8
POLICY_SOURCE_MAX_ITEMS_PER_PROVIDER=50
POLICY_SYNC_MAX_CONCURRENT_REQUESTS=3
POLICY_PROVIDER_GOV_CN_ENABLED=true
POLICY_PROVIDER_NPC_ENABLED=true
POLICY_PROVIDER_PBC_ENABLED=true
POLICY_PROVIDER_CSRC_ENABLED=true
POLICY_PROVIDER_NDRC_ENABLED=true
POLICY_PROVIDER_MIIT_ENABLED=true
STOCK_RELATED_NEWS_CACHE_TTL_SECONDS=3600
ANALYSIS_WORKER_POLL_INTERVAL_SECONDS=5
ANALYSIS_RUNNING_STALE_SECONDS=900

# =========================
# LLM / 联网增强
# =========================
LLM_BASE_URL=https://api.openai.com
LLM_WIRE_API=responses
LLM_API_KEY=
LLM_MODEL=gpt-5.1-codex-mini
LLM_REASONING_EFFORT=high
LLM_STREAM_ENABLED=true
LLM_WEB_SEARCH_ENABLED=false

# =========================
# Frontend（按需）
# =========================
VITE_API_BASE_URL=http://127.0.0.1:8000
